      [AUXILIARY_VARIABLE_37]
         SYMBOL = 'AIR'
         ID = 130
         DESCRIPTION = 'AIR, Concentration of Oxygen in Air corrected for pressure and temperature, g/m3'
         ONLINE_HELP = 'AIR Online help'
         DOCUMENTATION = 'AIR Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
