      [PROCESS_28]
         SYMBOL = 'consolSOC'
         ID = 159
         DESCRIPTION = 'consolSOC, Consolidation of layer 1 to layer 2, SOC1-->SOC2, g C/m2/d'
         ONLINE_HELP = 'consolSOC Online help'
         DOCUMENTATION = 'consolSOC Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'undefined'
         EXPRESSION = '"IF SOC0>0 THEN SOC0*Trans ELSE 0"'
      EndSect  // PROCESS_28

      [PROCESS_29]
         SYMBOL = 'minSOC'
         ID = 160
         DESCRIPTION = 'minSOC, Mineralisation of sediment organic C, gC/m2/d'
         ONLINE_HELP = 'minSOC Online help'
         DOCUMENTATION = 'minSOC Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'gC/m2/d'
         EXPRESSION = '"krsoc*SOC0*POW(tetn,Temp_soil-20)
*MIN(1,MAX(0.0001,son_soc-knim)/(pnre-knim))"'
      EndSect  // PROCESS_29

      [PROCESS_30]
         SYMBOL = 'rson'
         ID = 161
         DESCRIPTION = 'rson, Mineralisation of organic sediment N, g N/m2/d'
