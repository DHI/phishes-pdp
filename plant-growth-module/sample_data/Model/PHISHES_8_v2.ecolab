      [PROCESS_23]
         SYMBOL = 'updateLAI_1'
         ID = 154
         DESCRIPTION = 'updateLAI_1, Update LAI calculation, 1/d'
         ONLINE_HELP = 'updateLAI Online help'
         DOCUMENTATION = 'updateLAI Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = '1/d'
         EXPRESSION = '"(estimate_LAI_1-LAI_2D)*86400/dt*IF(BCc>0,0,1)"'
      EndSect  // PROCESS_23

      [PROCESS_24]
         SYMBOL = 'prrd'
         ID = 155
         DESCRIPTION = 'prrd, Root length increase rate, mm/d'
         ONLINE_HELP = 'prrd Online help'
         DOCUMENTATION = 'prrd Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'mm/d'
         EXPRESSION = '"re_cor*(1+1.5*((max_rd*1000-RD_2D)/(max_rd*1000)))*1000*if(prbc_b>0,1,0)


/*IF(RD_2D>=max_rd*1000,0,(1-EXP(-re_cor/max_rd))*1000)*/"'
      EndSect  // PROCESS_24

      [PROCESS_25]
         SYMBOL = 'deLAI'
         ID = 156
         DESCRIPTION = 'deLAI, Decrease in LAI due to crop dring out and plants dying, 1/d'
         ONLINE_HELP = 'deLAI Online help'
         DOCUMENTATION = 'deLAI Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = '1/d'
         EXPRESSION = '"if(BCc>0, LAI_2D*kdLAI,0)"'
      EndSect  // PROCESS_25

