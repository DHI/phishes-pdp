         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'gN/m2/d'
         EXPRESSION = '"prcr*bn_bc_a"'
      EndSect  // PROCESS_2

      [PROCESS_3]
         SYMBOL = 'bc_growth'
         ID = 134
         DESCRIPTION = 'bc_growth, Total crop growth, gC/m2/d'
         ONLINE_HELP = 'bc_growth Online help'
         DOCUMENTATION = 'bc_growth Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'gC/m2/d'
         EXPRESSION = '"mybc*myte*myi*BCa_2D*r_d*fLAI"'
      EndSect  // PROCESS_3

      [PROCESS_4]
         SYMBOL = 'prbc_a'
         ID = 135
         DESCRIPTION = 'prbc_a, above ground biomass carbon production, g C/m2/d'
         ONLINE_HELP = 'prbc Online help'
         DOCUMENTATION = 'prbc Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'gC/m2/d'
         EXPRESSION = '"bc_growth*rcrop0"'
      EndSect  // PROCESS_4

      [PROCESS_5]
         SYMBOL = 'rebc_a'
         ID = 136
         DESCRIPTION = 'rebc_a, Crop above cround biomass respiration, gC/m2/d'
         ONLINE_HELP = 'rebc_a Online help'
         DOCUMENTATION = 'rebc_a Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'gC/m2/d'
         EXPRESSION = '"((1-r_d)*rbma_d*POW(tetb,(temp_AT-20))+r_d*rbma_l*POW(tetb,(temp_AT-20))) *BCa_2D*fLAI_r"'
      EndSect  // PROCESS_5

