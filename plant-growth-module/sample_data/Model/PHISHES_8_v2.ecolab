         UNIT = 'g N/m2/d'
         EXPRESSION = '"kmsn*minSOC*son_soc"'
      EndSect  // PROCESS_30

      [PROCESS_31]
         SYMBOL = 'consolSON'
         ID = 162
         DESCRIPTION = 'consolSON, consolidation of SON, g N/m2/d'
         ONLINE_HELP = 'consolSON Online help'
         DOCUMENTATION = 'consolSON Documentation'
