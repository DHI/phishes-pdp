         ID = 164
         DESCRIPTION = 'upbn_b Description'
         ONLINE_HELP = 'upbn_b Online help'
         DOCUMENTATION = 'upbn_b Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'undefined'
         EXPRESSION = '"0"'
      EndSect  // PROCESS_33

      [PROCESS_34]
         SYMBOL = 'rsnit'
         ID = 165
         DESCRIPTION = 'rsnit, Nitrification sediment, g N/m3/d'
         ONLINE_HELP = 'rsnit Online help'
         DOCUMENTATION = 'rsnit Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'g N/m3/d'
         EXPRESSION = '"if(NH4*knit*POW(tetn,Temp_soil-20)*(DO)/((DO)+0.01)*NH4/(NH4+hmt)>DO/4.57,DO/4.57,NH4*knit*POW(tetn,Temp_soil-20)*(DO)/((DO)+0.01)*NH4/(NH4+hmt))*IF (NH4>=0.00001,1 ,0)"'
      EndSect  // PROCESS_34

      [PROCESS_35]
         SYMBOL = 'rdenit'
         ID = 166
         DESCRIPTION = 'rdenit, denitrification, gN/m3/d'
         ONLINE_HELP = 'rdenit Online help'
         DOCUMENTATION = 'rdenit Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'gN/m3/d'
         EXPRESSION = '"IF DO < mdo3 && NO3>0.0001 THEN kden*POW(tetn,Temp_soil-20)*(ksb+0.1)

/MAX(0.01,(ksb+0.1+DO))*NO3/MAX(0.001,(NO3+hno3))*(minSOC*0.75)/MAX(0.001,(minSOC*0.75+hudc))

 ELSE 0"'
      EndSect  // PROCESS_35

      [PROCESS_36]
         SYMBOL = 'feuno3'
         ID = 167
         DESCRIPTION = 'feuno3 Description'
         ONLINE_HELP = 'feuno3 Online help'
         DOCUMENTATION = 'feuno3 Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'undefined'
         EXPRESSION = '"0"'
      EndSect  // PROCESS_36

      [PROCESS_37]
         SYMBOL = 'fAir'
         ID = 168
         DESCRIPTION = 'fAir, Flux of Oxygen from air to arated pore volume, g/m3/d'
         ONLINE_HELP = 'fAir Online help'
         DOCUMENTATION = 'fAir Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         PROCESS_TYPE = 'TRANSFORMATION'
         SCOPE = 'WC'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'undefined'
         EXPRESSION = '"if (rear_fraction < 0) then
   (AIR-AO)*86400/dt /* pull to saturation concentration */
else
  rear_fraction* min(Ka, 86400/dt) * (AIR-AO) /*apply rate not exeeding saturation concentration , potentially add temperature dependency*/"'
      EndSect  // PROCESS_37

