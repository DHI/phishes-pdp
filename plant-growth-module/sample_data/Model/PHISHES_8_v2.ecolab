/*SMOOTHING_AVERAGE(temp_AT, alfa)    if (acc_ts<no_ts*dt, temp_AT,SMOOTHING_AVERAGE(temp_AT,alfa))*/"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_13

      [AUXILIARY_VARIABLE_14]
         SYMBOL = 'ios_unit'
         ID = 107
         DESCRIPTION = 'ios_unit, converting light units, E/m2/d'
         ONLINE_HELP = 'ios_unit Online help'
         DOCUMENTATION = '(ios_eco*86400/1000) /*conversion to kJ/m2/d*/ *VisibleLightFraction*(1/wave550energy) /*convert to mol/(m2*d)*/'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'E/m2/d'
         EXPRESSION = '"ios_she*86400 /1000/*conversion to kJ/m2/d*/ *VisibleLightFraction*(1/wave550energy) /*convert to mol/(m2*d)*/"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_14

      [AUXILIARY_VARIABLE_15]
         SYMBOL = 'io'
         ID = 108
         DESCRIPTION = 'io, Available light for growth corrected fro LAI, E/m2/d'
         ONLINE_HELP = 'ios0 Online help'
         DOCUMENTATION = 'ios0 Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'E/m2/d'
         EXPRESSION = '"ios_unit*(1-EXP(-k_lai*LAI_2D))"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_15

      [AUXILIARY_VARIABLE_16]
         SYMBOL = 'myte'
         ID = 109
         DESCRIPTION = 'myte, temperature dependency for growth, nu'
         ONLINE_HELP = 'myte Online help'
         DOCUMENTATION = 'myte Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'nu'
         EXPRESSION = '"If ( temp_AT>tmax, LASSITER(lasa,mabce,topt,tmax,tmax), LASSITER(lasa,mabce,topt,tmax,temp_AT))"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_16

      [AUXILIARY_VARIABLE_17]
         SYMBOL = 'r_d'
         ID = 110
         DESCRIPTION = 'r_d, Relative day lenght, nu'
         ONLINE_HELP = 'Auxiliary_4 Online help'
         DOCUMENTATION = ''
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'nu'
         EXPRESSION = '"RELATIVE_DAYLENGTH(YEAR(),MONTH(),DAY(),latitu)"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_17

      [AUXILIARY_VARIABLE_18]
         SYMBOL = 'ihb'
         ID = 111
         DESCRIPTION = 'ihb, light inhibition for bc at 20 degrees, E/m2/d'
         ONLINE_HELP = 'ihb Online help'
         DOCUMENTATION = 'ihb Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'E/m2/d'
         EXPRESSION = '"ihb20*POW(tetl,(temp_AT-20))"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_18

      [AUXILIARY_VARIABLE_19]
         SYMBOL = 'ikb'
         ID = 112
         DESCRIPTION = 'ikb, light saturation level for growth, E/m2/d'
         ONLINE_HELP = 'ikb Online help'
         DOCUMENTATION = 'ikb Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'E/m2/d'
         EXPRESSION = '"ike20*POW(tetk,temp_AT-20)"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_19

      [AUXILIARY_VARIABLE_20]
         SYMBOL = 'icb'
         ID = 113
         DESCRIPTION = 'icb, Compenstation light function correction to temperature, E/m2/d'
         ONLINE_HELP = 'icb Online help'
         DOCUMENTATION = 'icb Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'µE/m2/s'
         EXPRESSION = '"icb20*POW(tetk,temp_AT-20)"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_20

      [AUXILIARY_VARIABLE_21]
         SYMBOL = 'myi'
         ID = 114
         DESCRIPTION = 'myi, light availability for growth of BC, nu'
         ONLINE_HELP = 'myi Online help'
         DOCUMENTATION = 'myi Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'nu'
         EXPRESSION = '"IF (io>ihb) THEN MAX(0, (1-(io-ihb)/(ikb-icb))) ELSE MAX(0,(MIN(io,ikb)-icb)/(ikb-icb))"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_21

      [AUXILIARY_VARIABLE_22]
         SYMBOL = 'estimate_LAI_1'
         ID = 115
         DESCRIPTION = 'estimate_LAI_1, LAI estimation based on above ground biomass, nu'
         ONLINE_HELP = 'estimate_LAI Online help'
         DOCUMENTATION = 'estimate_LAI Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'nu'
         EXPRESSION = '"IF(BCa_2D<=0 || BCc>0,0, max_LAI/(1+EXP(-0.01013*(BCa_2D-212.93))))"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_22

      [AUXILIARY_VARIABLE_23]
         SYMBOL = 'fLAI'
         ID = 116
         DESCRIPTION = 'fLAL, LAI limitation to growth rates, nu'
         ONLINE_HELP = 'fLAI Online help'
         DOCUMENTATION = 'fLAI Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'nu'
         EXPRESSION = '"(POW(kmLAI,n)/(POW(kmLAI,n)+POW(LAI_2D,n)))*IF(BCc>0,0,1)


/*(LAI_2D/(max_LAI*0.001+LAI_2D))*/"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_23

      [AUXILIARY_VARIABLE_24]
         SYMBOL = 'fLAI_r'
         ID = 117
         DESCRIPTION = 'fLAI_r, LAI limitation for respiration and death'
         ONLINE_HELP = 'fLAIg Online help'
         DOCUMENTATION = 'fLAIg Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'undefined'
         EXPRESSION = '"(LAI_2D/(max_LAI*0.1+LAI_2D))"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_24

      [AUXILIARY_VARIABLE_25]
         SYMBOL = 'fbd'
         ID = 118
         DESCRIPTION = 'fbd, soil bulk density effect on root growth, nu'
         ONLINE_HELP = 'fbd Online help'
         DOCUMENTATION = 'fbd Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'nu'
         EXPRESSION = '"MIN(1,EXP(-4.3*(density-1.3)))"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_25

      [AUXILIARY_VARIABLE_26]
         SYMBOL = 're_cor'
         ID = 119
         DESCRIPTION = 're_cor, Root elongation rate correcton for limiting factors, m/d'
         ONLINE_HELP = 're_cor Online help'
         DOCUMENTATION = 're_cor Documentation'
         EUM_TYPE = 999
         EUM_UNIT = 0
         OUTPUT = 'YES'
         SCOPE = 'NOT_SPECIFIED'
         SPATIAL_VARIATION = 'HORISONTAL_AND_VERTICAL'
         UNIT = 'm/d'
         EXPRESSION = '"krd*fbd *IF(BCb_2D>0,1,0)*(1-(LAI_2D/max_LAI))*IF(Temp_soil >5,1,0)


/*krd*(1-(BCb_2D/(1000+BCb_2D)))*fbd *IF(BCb_2D>0,1,0)*fLAI_r*/

/* Temperature?? Add water limitation*/"'
         CALCULATION_TYPE = 'STANDARD'
      EndSect  // AUXILIARY_VARIABLE_26

